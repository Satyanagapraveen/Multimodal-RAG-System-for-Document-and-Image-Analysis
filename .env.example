# Multimodal RAG System - Environment Configuration
# Copy this file to .env and fill in your values

# Required: Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# CLIP embedding model
EMBEDDING_MODEL=clip-ViT-B-32

# ChromaDB storage path
CHROMA_DB_PATH=./chroma_db

# Extracted images storage path
EXTRACTED_IMAGES_PATH=./extracted_images

# Sample documents path
SAMPLE_DOCUMENTS_PATH=./sample_documents

# Retrieval settings
TEXT_RESULTS=5
IMAGE_RESULTS=3
TABLE_RESULTS=3
DISTANCE_THRESHOLD=0.75

# Generation settings
MAX_IMAGES_IN_CONTEXT=3
MAX_TEXT_CONTEXT_CHARS=8000
